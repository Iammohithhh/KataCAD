# Auto-detect text files
* text=auto

# Git LFS for CAD asset binaries (used Phase 6+)
*.step filter=lfs diff=lfs merge=lfs -text
*.stp filter=lfs diff=lfs merge=lfs -text
*.stl filter=lfs diff=lfs merge=lfs -text
*.glb filter=lfs diff=lfs merge=lfs -text
*.3mf filter=lfs diff=lfs merge=lfs -text

# The Layer 3 FAISS index is small (~1 MB) and ships inside the Docker
# image. Stored as a regular binary blob (not LFS) so a plain `git clone`
# on Railway / Vercel sees the real binary instead of an LFS pointer text.
*.faiss binary
