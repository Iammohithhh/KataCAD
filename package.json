{
  "name": "katacad",
  "version": "0.1.0",
  "private": true,
  "description": "KatACAD exhibition demo monorepo",
  "scripts": {
    "dev": "pnpm --parallel --filter=web --filter=api dev",
    "lint": "pnpm --parallel --filter=web lint",
    "build": "pnpm --filter=web build",
    "typecheck": "pnpm --parallel --filter=web --filter=shared exec tsc --noEmit"
  },
  "devDependencies": {
    "typescript": "^5.4.0"
  },
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  },
  "packageManager": "pnpm@9.0.0"
}
